APP_NAME=DataWhisperer AI
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

BACKEND_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

LOG_LEVEL=INFO

FRONTEND_BACKEND_URL=http://localhost:8000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_TIMEOUT_SECONDS=20
GEMINI_MAX_RETRIES=2
GEMINI_TEMPERATURE=0.2

CHAT_HISTORY_PATH=data/chat_history.json
CHAT_MEMORY_LIMIT=10
